# DOCKER COMPOSE
COMPOSE_PROJECT_NAME=streaming_system

# SYSTEM IDENTIFICATION
STREAM_INSTANCE_ID=stream1

# KAFKA
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=commodity_prices
KAFKA_CONSUMER_GROUP=spark_stream_raw_prices
KAFKA_LAG_POLL_SEC=60

# TWELVE DATA API
TD_API_KEY=your_api_key_here
TD_BASE=https://api.twelvedata.com
SOURCE=twelvedata_rest
INTERVAL_SEC=360

# POSTGRES (PRIMARY DATABASE)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=commodities
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# GRAFANA DATABASE ACCESS (READ-ONLY USER) | Used by Grafana datasource to read analytics tables
GRAFANA_DB_USER=grafana_read
GRAFANA_DB_PASSWORD=change_me

# SPARK STREAMING DATABASE ACCESS | Used by spark-stream container to write raw events
SPARK_DB_USER=spark_writer
SPARK_DB_PASSWORD=change_me

# SPARK JDBC TIMEOUTS (seconds) | PostgreSQL driver connect/socket timeouts
JDBC_CONNECT_TIMEOUT=10
JDBC_SOCKET_TIMEOUT=30

# DBT DATABASE ACCESS | Used by dbt container to build analytics models
DBT_DB_USER=dbt_runner
DBT_DB_PASSWORD=change_me

# PRODUCER DATABASE ACCESS | Used by API producer to log API metrics
PRODUCER_DB_USER=producer_writer
PRODUCER_DB_PASSWORD=change_me

# BACKUP DATABASE ACCESS | Used by backup service (pg_dump)
BACKUP_DB_USER=backup_user
BACKUP_DB_PASSWORD=change_me

# GRAFANA ADMIN LOGIN
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me

# PGADMIN (DEV ONLY)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=change_me

# ALERT RECEIVER WEBHOOK AUTH | Disabled for local dev (set ALERT_WEBHOOK_TOKEN in production)
ALERT_WEBHOOK_AUTH_DISABLED=true
