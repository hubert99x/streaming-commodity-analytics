      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with latest_hour as (\r\n    select max(hour_bucket) as hour_bucket\r\n    from analytics.mart_price_volatility_1h\r\n),\r\n\r\nvolatility as (\r\n    select\r\n        symbol,\r\n        avg_price,\r\n        price_range,\r\n        range_pct\r\n    from analytics.mart_price_volatility_1h\r\n    where hour_bucket = (select hour_bucket from latest_hour)\r\n),\r\n\r\nmoves as (\r\n    select\r\n        symbol,\r\n        max(abs(price_change_pct)) as largest_move,\r\n        count(*) as events\r\n    from analytics.mart_price_events\r\n    where event_ts >= now() - interval '1 hour'\r\n    group by symbol\r\n)\r\n\r\nselect\r\n    v.symbol as \"Instrument\",\r\n\r\n    case\r\n        when v.symbol = 'EUR/USD'\r\n            then to_char(v.avg_price::numeric, 'FM9999999990.0000')\r\n        else\r\n            to_char(v.avg_price::numeric, 'FM9999999990.00')\r\n    end as \"Avg Price\",\r\n\r\n    round(v.price_range::numeric, 2) as \"Price Range\",\r\n    round(v.range_pct::numeric, 3) as \"Hourly Range\",\r\n    round(coalesce(m.largest_move,0)::numeric, 3) as \"Largest Move\",\r\n    coalesce(m.events,0) as \"Events\"\r\n\r\nfrom volatility v\r\nleft join moves m\r\n    on v.symbol = m.symbol\r\norder by v.range_pct desc;",
          "refId": "A",
          "sql": {
            "columns": [
