          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH current_utc AS (\r\n  SELECT now() AT TIME ZONE 'UTC' AS utc_ts\r\n)\r\n\r\nSELECT\r\n  'XAU/USD' as instrument,\r\n  CASE\r\n    WHEN (\r\n      (extract(dow FROM utc_ts) = 5 AND utc_ts::time >= TIME '22:00')\r\n      OR extract(dow FROM utc_ts) = 6\r\n      OR (extract(dow FROM utc_ts) = 0 AND utc_ts::time < TIME '22:00')\r\n    )\r\n    THEN '● CLOSED'\r\n    ELSE '● OPEN'\r\n  END AS status\r\n\r\nFROM current_utc\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n  'BTC/USD',\r\n  '● OPEN'\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n  'EUR/USD',\r\n  CASE\r\n    WHEN (\r\n      (extract(dow FROM utc_ts) = 5 AND utc_ts::time >= TIME '22:00')\r\n      OR extract(dow FROM utc_ts) = 6\r\n      OR (extract(dow FROM utc_ts) = 0 AND utc_ts::time < TIME '22:00')\r\n    )\r\n    THEN '● CLOSED'\r\n    ELSE '● OPEN'\r\n  END\r\nFROM current_utc;",
          "refId": "A",
